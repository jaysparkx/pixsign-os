generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  plan             String    @default("FREE")    // FREE | PRO | BUSINESS
  stripeCustomerId String?   @unique
  stripeSubId      String?   @unique
  stripeSubStatus  String?   // active | past_due | canceled | trialing
  docsThisMonth    Int       @default(0)
  docsResetAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  documents        Document[]
}

model Document {
  id             String      @id @default(uuid())
  title          String
  status         String      @default("DRAFT")
  signingOrder   String      @default("PARALLEL")
  message        String?
  expiresAt      DateTime?
  completedAt    DateTime?
  voidedAt       DateTime?
  voidReason     String?
  originalPath   String      // local file path: /uploads/originals/xxx.pdf
  signedPath     String?     // local file path after signing
  originalHash   String
  signedHash     String?
  senderName     String      @default("Document Sender")
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  fields         Field[]
  recipients     Recipient[]
  events         Event[]
}

model Field {
  id          String    @id @default(uuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   Recipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  page        Int
  x           Float
  y           Float
  width       Float
  height      Float
  type        String    // SIGNATURE | INITIALS | DATE | TEXT | CHECKBOX | NAME | EMAIL
  label       String?
  required    Boolean   @default(true)
  value       String?
  signedAt    DateTime?
  createdAt   DateTime  @default(now())
}

model Recipient {
  id           String    @id @default(uuid())
  documentId   String
  document     Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  name         String
  email        String
  role         String    @default("SIGNER")  // SIGNER | CC
  signingOrder Int       @default(1)
  status       String    @default("PENDING") // PENDING | SENT | VIEWED | SIGNED | DECLINED
  token        String    @unique @default(uuid())
  emailSentAt  DateTime?
  viewedAt     DateTime?
  signedAt     DateTime?
  declinedAt   DateTime?
  declineReason String?
  ipAddress    String?
  createdAt    DateTime  @default(now())

  fields       Field[]
  events       Event[]
}

model Event {
  id          String    @id @default(uuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipientId String?
  recipient   Recipient? @relation(fields: [recipientId], references: [id])
  type        String
  ip          String?
  meta        String?   // JSON string
  createdAt   DateTime  @default(now())
}

model ViewEvent {
  id          String   @id @default(uuid())
  documentId  String
  visitorId   String   // cookie-based fingerprint
  page        Int
  durationMs  Int
  scrollDepth Float    @default(0)  // 0.0 to 1.0
  ip          String?
  userAgent   String?
  location    String?  // "City, Country" from IP geolocation
  createdAt   DateTime @default(now())

  @@index([documentId, page])
  @@index([documentId, visitorId])
}
