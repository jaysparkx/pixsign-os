# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email — use Gmail app password or any SMTP
# Gmail: go to myaccount.google.com → Security → App Passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="you@gmail.com"
EMAIL_FROM_NAME="eSign"

# That's it. SQLite DB is created automatically at prisma/dev.db
# Uploaded files are stored in /public/uploads/ (auto-created)
